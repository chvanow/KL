(function ($) {
    function checkState(route, layer) {
        if (!layer) {
            layer = $('body');
        }
        var defer = new $.Deferred(function () {
            // wait init
            if (layer.data('init') !== true) {
                var fakeInterval = setInterval(function () {
                    if (layer.data('init') === true) {
                        clearInterval(fakeInterval);
                        defer.resolve(route);
                    }
                }, 100);
            }
        });

        if (layer.data('init') === true) {
            defer.resolve(route);
        }

        return defer;
    }

