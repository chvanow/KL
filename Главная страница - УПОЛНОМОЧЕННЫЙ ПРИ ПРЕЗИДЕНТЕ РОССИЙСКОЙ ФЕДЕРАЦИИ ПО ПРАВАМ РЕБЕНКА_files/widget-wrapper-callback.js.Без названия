/** callbacks for widget lazy-load */

function initPressCenterOnMain() {
    $('input[type=checkbox]').styler();
    $(window).trigger('after.lazyload');
    $(window).trigger('main.press.center.init');
}

function initMediaOnMainWidget() {
    $('#section-media .ya-share2').each(function () {
        var id = $(this).attr('id');
        Ya.share2(id, {
            content: {
                url: $(this).data('url'),
                title: $(this).data('title'),
                description: $(this).data('description'),
                image: $(this).data('image')
            },
            theme: {
                services: $(this).data('services')
            }
        });
    });

    $(window).trigger('media.init.ytube');
    $(window).trigger('iframe-init');
}

function initEventCalendarOnMain() {
    $(window).trigger('event.calendar.init');
}