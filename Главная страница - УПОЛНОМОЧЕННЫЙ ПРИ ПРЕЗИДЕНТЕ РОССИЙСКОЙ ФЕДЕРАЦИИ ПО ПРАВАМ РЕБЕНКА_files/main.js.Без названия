    // функция для фиксации плавающих блоков в сайдбаре
    function fixBlockAside(elem, elemParent, placeFix, indent) {
        if (elemParent.length <= 0) {
            return false;
        }
        if ($(window).scrollTop() <= elemParent.offset().top - indent) {
            elem.css({
                top: 0,
            }).removeClass("fix");
        } else if (
            $(window).scrollTop() >
            placeFix.height() - elem.height() - indent
        ) {
            elem.css({
                top:
                    placeFix.height() - elem.height() - elemParent.offset().top,
            }).removeClass("fix");
        } else {
            elem.css({
                top: indent,
            }).addClass("fix");
        }
    }

