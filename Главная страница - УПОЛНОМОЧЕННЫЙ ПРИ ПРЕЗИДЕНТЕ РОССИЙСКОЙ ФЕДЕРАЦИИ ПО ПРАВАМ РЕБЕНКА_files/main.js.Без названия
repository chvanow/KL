    // таблицы в новостях или статьях
    function replaceSubstring(str, oldSubstr, newSubstr) {
        var result = '';
        var startIndex = 0;
        var endIndex = 0;

        while ((endIndex = str.indexOf(oldSubstr, startIndex)) > -1) {
            result += str.slice(startIndex, endIndex) + newSubstr;
            startIndex = endIndex + oldSubstr.length;
        }

        result += str.slice(startIndex);

        return result;
      }

    // функция нахождения самого длинного слова в строке
    function findLongestWord(str) {

        const words = str.split(" ");

        let maxLength = 0;
        let longestWord = "";

        // Проходимся по каждому слову в массиве
        for (let i = 0; i < words.length; i++) {

          if (words[i].length > maxLength) {

            maxLength = words[i].length;
            longestWord = words[i];
          }
        }

        return longestWord;
      }

    function adjustColumnWidths(wrapper, table) {
        const rows = table.querySelectorAll("tr");
        table.removeAttribute("style");
        // Находим все ячейки в первом ряду таблицы
        const headerCells = table.rows[0].cells;

        const stylesTd = [];

        for (let i = 0; i < rows.length; i++) {
            const cells = rows[i].querySelectorAll("td");

            stylesTd[i] = [];

            for (let j = 0; j < cells.length; j++) {
                let styles = '';
                // сохраняем в двумерный массив старые значения инлайновых стилей ячеек без ширины
                if (cells[j].getAttribute("style")) {
                    styles = cells[j].getAttribute("style").match(/%;(.*)/);
                    if (styles != null){
                        if (styles.includes('vertical-align:bottom;')) {
                            styles = replaceSubstring(styles, 'vertical-align:bottom;', 'justify-content: flex-end;');
                        }

                        if (styles.includes('vertical-align:middle;')) {
                            styles = replaceSubstring(styles, 'vertical-align:middle;', 'justify-content: center;');
                        }
                    }
                }
                // Найти все картинки внутри элемента
                const images = cells[j].querySelectorAll('img');

                // Перебрать все найденные картинки
                images.forEach((image) => {
                    // Получить атрибуты width и height
                    const width = image.getAttribute('width');
                    const height = image.getAttribute('height');

                    // Задать полученные значения как атрибуты стиля
                    image.style.maxWidth = `${width}px`;
                    image.style.maxHeight = `${height}px`;
                });

                stylesTd[i][j] = styles;

                cells[j].removeAttribute("style");

            }
        }

        const columnWidths = new Array(headerCells.length).fill(0);

        // Проходимся по всем ячейкам таблицы и находим максимальную высоту каждого столбца
        // а также максимальную ширину каждой строки в столбце

        for (let i = 0; i < headerCells.length; i++) {
            const cells = table.querySelectorAll(`td:nth-child(${i + 1})`);

            let maxWidth = 0;
            for (let j = 0; j < cells.length; j++) {
                const cell = cells[j];

                // cellWidth = Math.min(findLongestWord(cell.textContent).length, cell.offsetWidth);
                cellWidth = cell.getBoundingClientRect().width;
                // cellWidth = findLongestWord(cell.textContent).length;

                let cellTextWidth = cell.scrollWidth;

                if (cellTextWidth > cellWidth) {
                    cellWidth = cellTextWidth;
                }
                if (cellWidth > maxWidth) {
                    maxWidth = cellWidth;
                }
                if (maxWidth > 280) {
                    maxWidth = 280;
                }

                columnWidths[i] = maxWidth;
                const rowHeight = cell.offsetHeight;

                if (
                    rowHeight > cell.dataset.maxHeight ||
                    !cell.dataset.maxHeight
                ) {
                    cell.dataset.maxHeight = rowHeight;
                }
            }
        }

        // Устанавливаем ширину каждого столбца равной его максимальной ширине
        const cells = [];

        for (let i = 0; i < rows.length; i++) {
            const cells = rows[i].querySelectorAll("td");

            for (let j = 0; j < cells.length; j++) {
                cells[j].removeAttribute("style");

                // возвращаем стили ячеек вместе с вычисленной шириной
                cells[j].setAttribute(
                    "style",
                    `width: ${columnWidths[j] + 5}px; ${stylesTd[i][j]}`
                );
            }
        }

        const add = (arr) => arr.reduce((a, b) => a + b, 0); // суммируем элементы массива

        tableWidth = add(columnWidths) + (5 * (columnWidths.length));

        if (tableWidth > wrapper.offsetWidth) {
            wrapper.setAttribute("style", "overflow-x: scroll !important; -webkit-overflow-scrolling: touch; overflow-scrolling: touch;");
        }

        table.setAttribute("style", `width: ${tableWidth}px`);

        // Устанавливаем высоту каждой ячейки равной ее максимальной высоте
        for (let i = 0; i < rows.length; i++) {
            const cells = rows[i].querySelectorAll("td");
            for (let j = 0; j < cells.length; j++) {
                const cell = cells[j];
                cell.style.height = `${cell.dataset.maxHeight}px`;
            }
        }
    }

