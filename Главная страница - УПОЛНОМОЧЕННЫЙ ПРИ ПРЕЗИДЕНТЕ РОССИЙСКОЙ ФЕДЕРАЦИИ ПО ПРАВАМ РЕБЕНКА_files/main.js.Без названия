            }
            else{
                thisFloatNav.css('top', thisfloatPos + (thisCustomTable.height()/2) - 16);
            }
            if (st > scrollPos) {
                thisFloat.removeClass("under");
                thisFloatNav.removeClass("under");
            } else {
                thisFloat.addClass("under");
                thisFloatNav.addClass("under");            
            }
        });
        
        if (st > scrollPos) {
            $(".header-fix").removeClass("visible");
        } else {
            $(".header-fix").addClass("visible");          
        }
        scrollPos = st;

    });

