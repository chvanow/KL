    // картинки в новостях и статьях

    const textBlocks = document.querySelectorAll(".text-block");

    textBlocks.forEach(tblock => {
        const images = tblock.querySelectorAll("img");

        // Перебрать все найденные картинки
        images.forEach((image) => {

            // находим натуральные размеры картинки
            const realWidth = image.naturalWidth;
            const realHight = image.naturalHeight;

            const delived = realWidth / realHight;

            let floatSt = ''

            let styles = '';
            if (image.getAttribute("style")) {
                // styles = image.getAttribute("style").match(/%;(.*)/);
                styles = image.getAttribute("style")

                if (styles != null) {
                    if (styles.includes('float: left;') ||  styles.includes('float:left;')) {
                        floatSt = 'float: left; margin-right: 10px;';
                    }
                    if (styles.includes('float: right;') || styles.includes('float:right;')) {
                        floatSt = 'float: right; margin-left: 10px;';
                    }
                    if (styles.includes('margin-left: auto; margin-right: auto;') ||  styles.includes('margin-left:auto;margin-right:auto;')) {
                        floatSt = 'margin-left: auto; margin-right: auto;';
                    }
                }
            }

            // Получить атрибуты width и height
            let width = image.getAttribute('width');
            let height = image.getAttribute('height');

            if (width > 800) {
                width = '800';
                height = 800 / delived;
            }

            if (height > 600) {
                height = 600
