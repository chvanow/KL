window.atlas = {
    options: {
        svg_width: 1000,    // XXX magic numbers, need to be computed
        svg_height: 580,
        maxScale: 'x2.5',
        shadow: 8,
        paths: null,
    },
    data: null,
    loading: false,
    _readyState: jQuery.Deferred(),
    init: function () {
        this.getData();
    },
    ready: function () {
        return this._readyState.promise();
    },
    resolve: function(){
        this._readyState.resolve();
        window.atlas.loading = false;
    },
    getData: function() {
        if(!window.atlas.data && !window.atlas.loading) {
            window.atlas.loading = true;
            $.ajax({
                'url': '/static/default/map/data/russia.json',
                'dataType': 'json',
                'success': function (resp) {
                    window.atlas.data = resp;
                    window.atlas.getPaths();
                }
            });
        }
    },
    getPaths: function() {
        if(!window.atlas.options.paths) {
            $.ajax({
                'url': '/static/default/map/paths/russia.json',
                'dataType': 'json',
                'success': function (resp) {
                    window.atlas.options.paths = resp;
                    window.atlas.resolve();
                }
            });
        }
    }
}
